{
  "name": "worktrack-cam",
  "version": "0.1.0",
  "private": true,
  "description": "WorkTrackCAM — CNC toolpath generation, FDM slicing, and machine management",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "verify:release-gate": "node scripts/verify-release-gate.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "electron-updater": "^6.8.3",
    "handlebars": "^4.7.8",
    "json5": "^2.2.3",
    "smol-toml": "^1.6.1",
    "three": "^0.183.2",
    "yaml": "^2.8.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^7.0.3",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8"
  },
  "build": {
    "productName": "WorkTrackCAM",
    "appId": "com.worktrack.cam",
    "artifactName": "${productName}-${version}-Setup.${ext}",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "engines",
        "to": "engines",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "publisherName": "WorkTrack",
      "icon": "build/icons/icon.ico"
    },
    "linux": {
      "icon": "build/icons/icon.png"
    },
    "mac": {
      "icon": "build/icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WorkTrackCAM"
    },
    "fileAssociations": [
      {
        "ext": "wtcam",
        "name": "WorkTrackCAM Project",
        "description": "WorkTrackCAM project file",
        "role": "Editor"
      }
    ]
  }
}
