exports[`Snapshot — tool changes (Heidenhain) > tool T2 M6 + G43 H2 1`] = `
"; Comprehensive Snapshot Mill — snapshot-comprehensive
; 4-AXIS (A-ROTARY) G-CODE — Heidenhain TNC (DIN/ISO mode)
; ---------------------------------------------------------------------------
; UNVERIFIED G-CODE — verify every line against your Heidenhain TNC manual
; before running on a machine. Output is not guaranteed safe for any machine.
; ---------------------------------------------------------------------------
; CRITICAL 4TH AXIS CHECKS BEFORE RUNNING:
; (1) Switch the TNC to DIN/ISO mode (not Klartext). This program uses
;     standard G-code, not Heidenhain conversational format.
; (2) Confirm the rotary table or chuck is firmly clamped and the A-axis
;     motor is enabled in machine parameters (MP).
; (3) Confirm the workpiece is centred on the rotary axis — off-centre
;     stock causes gouging and crashes.
; (4) Confirm cylinder diameter matches the value used to generate toolpaths.
; (5) Set A-axis datum — use the TNC Datum Setup screen to zero the A axis
;     at your reference position.
; (6) Air-cut with spindle off at 10% feed override before a real cut.
; (7) Confirm your TNC machine parameters for the A-axis are correct:
;     axis limits, acceleration, max RPM. Check MP7420 (axis assignment)
;     and MP1000 (rotary axis configuration).
; ---------------------------------------------------------------------------
; Retract order: lift Z to safe clearance before commanding large A moves.
; Before production: dry run — spindle off, Z high, feed reduced.
; See docs/MACHINES.MD — safe Z, WCS, units, spindle M-codes.
; ---------------------------------------------------------------------------
; Work area (mm): 300 x 200 x 100
; A-axis range: 360 deg — verify against TNC MP axis limits
; --- Safety header ---
G21              ; millimeters — must match TNC setting
G90                    ; absolute distance mode (X Y Z A all absolute)
G17                    ; XY plane for G2/G3 arcs
G40                    ; cancel cutter radius compensation
G49                    ; cancel tool length compensation
G80                    ; cancel canned cycles
; Operation: Heidenhain Tool T2
; --- Tool call (Heidenhain DIN/ISO mode — verify tool in TNC tool table) ---
T2 M6                  ; select tool 2 and execute tool change
G43 H2                 ; apply tool length compensation from TNC tool table
; Home / safe position — retract Z before rotating A to avoid collisions
G0 Z100   ; safe Z retract — adjust to your actual safe clearance
; Spindle on (Heidenhain — confirm S value and M3/M4 match your spindle config)
M3 S10000
; --- 4-axis toolpath moves begin (X Y Z A words) ---
G0 X0 Y0 Z20 A0
G1 X10 Z-2.000 A0 F600
G1 X10 Z-2.000 A90 F400
G1 X10 Z-2.000 A180 F400
G1 X10 Z-2.000 A270 F400
G0 Z20 A0
; --- end toolpath ---
; Spindle off
M5
; Safe retract and park
G0 Z100   ; full retract for unload
G0 A0                  ; return A-axis to zero
G0 X0 Y0              ; park X Y — adjust to your preferred park position
M30                    ; program end
"
`;

exports[`Snapshot — tool changes (LinuxCNC) > default tool T1 M6 + G43 H1 1`] = `
"%
; Comprehensive Snapshot Mill — snapshot-comprehensive
; 4-AXIS (A-ROTARY) G-CODE — linuxcnc_4axis dialect
; ---------------------------------------------------------------------------
; UNVERIFIED G-CODE — verify every line against your LinuxCNC INI/HAL
; configuration and your rotary attachment manual before running on the machine.
; ---------------------------------------------------------------------------
; CRITICAL 4TH AXIS CHECKS BEFORE RUNNING:
; (1) Confirm the rotary attachment is firmly clamped to the table and the
;     A-axis motor/driver is enabled in your LinuxCNC INI file ([AXIS_A] section).
; (2) Confirm the workpiece is centred on the rotary chuck — off-centre
;     stock causes gouging and crashes.
; (3) Confirm cylinder diameter matches the value used to generate toolpaths.
; (4) Set A-axis WCS zero (usually the left face of the cylinder, A=0).
;     Use LinuxCNC AXIS GUI or GMOCCAPY DRO to zero the A axis at your
;     reference position.
; (5) Air-cut with spindle off at 10% feed override before a real cut.
; (6) Confirm your LinuxCNC INI has [AXIS_A] properly configured:
;     MAX_VELOCITY, MAX_ACCELERATION, MIN_LIMIT, MAX_LIMIT must match
;     your rotary table capabilities and stepper/servo tuning.
; (7) Confirm HOME_SEQUENCE and homing parameters for the A axis are set
;     if your rotary table has a home switch.
; ---------------------------------------------------------------------------
; Retract order: lift Z to a safe radial clearance before commanding large A moves
; (toolpath lines already use clearance Z between passes; header retract is machine max Z).
; Before production: dry run — spindle off, Z high, feed reduced.
; Compare a short program to a known-good file from your CAM package.
; See docs/MACHINES.MD — safe Z, WCS, units, spindle M-codes.
; ---------------------------------------------------------------------------
; Work area (mm): 300 x 200 x 100
; A-axis range: +/-360 deg (verify against INI [AXIS_A] MIN_LIMIT / MAX_LIMIT)
; --- Safety header ---
G21              ; millimeters — must match LinuxCNC INI [TRAJ] LINEAR_UNITS = mm
G90              ; absolute distance mode (X Y Z A all absolute)
G17              ; XY plane for G2/G3 arcs; switch to G18 (XZ) if needed for 4-axis arcs
G40              ; cancel cutter radius compensation
G49              ; cancel tool length compensation
G80              ; cancel canned cycles
; Operation: LinuxCNC Default Tool
; --- Tool call (LinuxCNC supports M6 tool change with T-word) ---
; Verify tool number, length offset, and diameter in LinuxCNC tool table.
T1 M6            ; select tool 1 and execute tool change
G43 H1           ; apply tool length compensation from tool table entry 1
; Home / safe position — retract Z before rotating A to avoid collisions
G0 Z100 ; safe Z retract — adjust to your actual safe clearance
; Spindle on (LinuxCNC — confirm S value and M3/M4 match your spindle HAL config)
M3 S12000
; --- 4-axis toolpath moves begin (X Y Z A words) ---
G0 X0 Y0 Z20 A0
G1 X10 Z-2.000 A0 F600
G1 X10 Z-2.000 A90 F400
G1 X10 Z-2.000 A180 F400
G1 X10 Z-2.000 A270 F400
G0 Z20 A0
; --- end toolpath ---
; Spindle off
M5
; Retract Z to machine max clearance before parking
; (Toolpath already returns A to 0 deg and retracts Z to clearance;
;  this final retract ensures the tool is at machine-max Z for unload.)
G0 Z100 ; full retract for unload
G0 A0            ; return A-axis to zero
G0 X0 Y0         ; park X Y — adjust to your preferred home position
M2               ; program end — LinuxCNC convention (M2 preferred over M30)
%
"
`;

