// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Snapshot — 5-axis templates with options > Fanuc 5-axis with tool number T3 and WCS G55 1`] = `
"; Comprehensive Snapshot Mill — snapshot-comprehensive
; 5-AXIS SIMULTANEOUS G-CODE — Fanuc dialect
; ---------------------------------------------------------------------------
; UNVERIFIED G-CODE — verify every line against your controller manual before
; running on a machine. Output is not guaranteed safe for any real machine.
; ---------------------------------------------------------------------------
; CRITICAL 5-AXIS CHECKS BEFORE RUNNING:
; (1) Confirm machine kinematic type matches profile (table-table, table-head,
;     or head-head). Wrong kinematics = wrong tool tip position = CRASH.
; (2) Confirm G43.4 (RTCP / TCP) is available and calibrated on your control.
;     Without RTCP, the programmed XYZ point is the rotary center, NOT the
;     tool tip — the tool will gouge or miss the part.
; (3) Confirm A-axis and B-axis travel limits match the profile ranges.
; (4) Confirm tool length compensation (H value) is correct — G43.4 uses it.
; (5) Air-cut with spindle off at 10% feed override before any real cut.
; (6) Watch for singularities near A=0/B=0 (gimbal lock region) — feed may
;     spike. Reduce override near vertical orientations.
; ---------------------------------------------------------------------------
; Work area (mm): 300 x 200 x 100
; A-axis range: 360°
; B-axis range: 120°
; Kinematic chain: table-head
; Max tilt from vertical: 60°
G21        ; G21=mm / G20=inch — must match controller defaults
G90              ; absolute distance mode (X Y Z A B all absolute)
G17              ; XY plane for arcs
G40 G49 G80     ; cancel cutter comp, tool length comp, canned cycles
; Active work offset — verify fixture zero matches G54–G59 selection
G55
; Operation: 5ax Fanuc T3 G55
; --- RTCP (Rotary Tool Center Point) ---
; G43.4 tells the control to keep the tool tip at programmed XYZ regardless
; of A/B rotation. Remove this line ONLY if your post-processor already
; accounts for kinematic offsets in the XYZ coordinates.
G43.4 H3        ; RTCP on — verify H number matches your tool offset
; Spindle on
M3 S10000
; --- 5-axis toolpath moves begin (X Y Z A B words) ---
G0 X0 Y0 Z30 A0 B0
G1 X10 Y10 Z-1.000 A15 B10 F500
G1 X20 Y10 Z-1.000 A30 B-5 F500
G1 X20 Y20 Z-1.500 A15 B0 F500
G0 Z30 A0 B0
; --- end toolpath ---
; Spindle off
M5
; Cancel RTCP before retracting
G49              ; cancel tool length / RTCP
; Safe retract
G0 Z100
G0 A0 B0         ; return rotary axes to zero
G0 X0 Y0         ; park — adjust to your safe park position
M30
"
`;

exports[`Snapshot — 5-axis templates with options > Siemens 5-axis with TRAORI and line numbering 1`] = `
"; Comprehensive Snapshot Mill — snapshot-comprehensive
; 5-AXIS SIMULTANEOUS G-CODE — Siemens Sinumerik dialect
; ---------------------------------------------------------------------------
; UNVERIFIED G-CODE — verify every line against your controller manual before
; running on a machine. Output is not guaranteed safe for any real machine.
; ---------------------------------------------------------------------------
; CRITICAL 5-AXIS CHECKS BEFORE RUNNING:
; (1) Confirm machine data (MD) for kinematic chain matches this profile.
;     TRAORI reads pivot point distances from MD — wrong MD = wrong TCP.
; (2) Confirm TRAORI is licensed and configured ($MC_TRAFO_TYPE_1, etc.).
; (3) Confirm A-axis and B/C-axis travel limits and soft limits.
; (4) Confirm tool length in the tool table (D1) is correct.
; (5) Air-cut with spindle off at 10% feed override before any real cut.
; (6) CYCLE800 (SWIVEL) may be needed before TRAORI if using tilted work
;     planes — this template does not emit CYCLE800.
; ---------------------------------------------------------------------------
; Work area (mm): 300 x 200 x 100
; A-axis range: 360°
; B-axis range: 120°
; Kinematic chain: table-table
; Max tilt from vertical: 60°
N10 G21        ; G21=mm / G20=inch — must match controller defaults
N20 G90              ; absolute distance mode
N30 G17              ; XY plane for arcs
; Operation: 5ax Siemens Numbered
; --- Activate 5-axis orientation transformation ---
; TRAORI tells Sinumerik to maintain tool tip at programmed XYZ regardless
; of rotary axis positions. This is mandatory for simultaneous 5-axis.
N40 TRAORI(1)        ; activate transformation — number matches your kinematic setup
; Spindle on
N50 M3 S10000
; --- 5-axis toolpath moves begin (X Y Z A B words) ---
N60 G0 X0 Y0 Z30 A0 B0
N70 G1 X10 Y10 Z-1.000 A15 B10 F500
N80 G1 X20 Y10 Z-1.000 A30 B-5 F500
N90 G1 X20 Y20 Z-1.500 A15 B0 F500
N100 G0 Z30 A0 B0
; --- end toolpath ---
; Spindle off
N110 M5
; Deactivate transformation before retracting
N120 TRAFOOF          ; transformation off
; Safe retract
N130 G0 Z100
N140 G0 A0 B0         ; return rotary axes to zero
N150 G0 X0 Y0         ; park — adjust to your safe park position
N160 M30
"
`;

exports[`Snapshot — WCS offsets > G54 (WCS index 1) 1`] = `
"; Comprehensive Snapshot Mill — snapshot-comprehensive
; ---------------------------------------------------------------------------
; UNVERIFIED G-CODE — verify every line against your controller before
; running on a machine. Output is not guaranteed safe for any real machine.
; ---------------------------------------------------------------------------
; Before production: (1) air cut / dry run — spindle off, Z high, reduced feed
; (2) single-axis jog tests if you changed WCS or macros (3) shallow first cut
; in soft stock (4) compare a short program to a known-good file for this control
; See docs/MACHINES.md — safe Z, WCS, units (G20/G21), spindle M-codes, arc support.
; ---------------------------------------------------------------------------
; Spindle/coolant: profile dialect inserts snippets below — Grbl, Mach3, and others
; differ on M3/M4/M5, S-word RPM, and coolant (M7/M8/M9). Confirm on your control.
; ---------------------------------------------------------------------------
; Tool change: this template does not emit M6, ATC macros, or tool-length comp.
; It assumes a single-tool program unless you add tool-change blocks yourself.
; Verify the full sequence (spindle stop, safe Z, M6/T/H if used) on your control
; before running multi-tool jobs.
; ---------------------------------------------------------------------------
; Work area (mm): 300 x 200 x 100
G21        ; G21=mm / G20=inch — must match controller defaults at power-on
G90              ; absolute distance mode
G17              ; XY plane (typical for G2/G3 arcs)
; Active work offset — verify fixture zero matches G54–G59 selection
G54
; Operation: WCS G54
; Spindle on (dialect from machine profile — change profile if M3/S/RPM differ)
M3 S12000
G0 X0 Y0 Z10
G0 X5 Y5 Z5
G1 Z-1.000 F300
G1 X15 Y5 F800
G1 X15 Y15 F800
G1 X5 Y15 F800
G1 X5 Y5 F800
G0 Z10
; Spindle off (dialect snippet — usually M5)
M5
; Retract Z to safe clearance and park (adjust to your machine's preferred home)
G0 Z100 ; safe Z retract — adjust to your actual safe clearance
G0 X0 Y0                     ; park X Y — adjust to your preferred home position
M30
"
`;

